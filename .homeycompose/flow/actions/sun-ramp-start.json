{
  "id": "sun-ramp-start",
  "title": {
    "en": "Virtual sun start"
  },
  "titleFormatted": {
    "en": "Virtual sun [[rampName]] • [[duration]] min • [[direction]] • [[step]] pp/step"
  },
  "args": [
    {
      "name": "rampName",
      "type": "autocomplete",
      "title": {
        "en": "Ramp name"
      },
      "placeholder": {
        "en": "morning-livingroom"
      }
    },
    {
      "name": "duration",
      "type": "number",
      "title": {
        "en": "Duration (minutes)"
      },
      "min": 1,
      "max": 1440,
      "step": 1,
      "placeholder": {
        "en": "60"
      }
    },
    {
      "name": "direction",
      "type": "dropdown",
      "title": {
        "en": "Direction"
      },
      "values": [
        {
          "id": "down",
          "title": {
            "en": "Down (100.0% to 0.0%)"
          }
        },
        {
          "id": "up",
          "title": {
            "en": "Up (0.0% to 100.0%)"
          }
        }
      ]
    },
    {
      "name": "step",
      "type": "number",
      "title": {
        "en": "Step (%)"
      },
      "value": 1,
      "min": 0.1,
      "max": 100,
      "step": 0.1,
      "placeholder": {
        "en": "1"
      }
    }
  ]
}
