{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.klintrot.virtualsun",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "brandColor": "#167AFF",
  "platforms": [
    "local",
    "cloud"
  ],
  "name": {
    "en": "Virtual Sun"
  },
  "description": {
    "en": "Adds support for MyBrand devices."
  },
  "category": [
    "tools"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Oskar Klintrot",
    "email": "oskar.klintrot@gmail.com"
  },
  "support": "mailto:oskar.klintrot@gmail.com",
  "flow": {
    "triggers": [
      {
        "id": "sun-value-changed",
        "title": {
          "en": "Sun value changed"
        },
        "titleFormatted": {
          "en": "Sun value changed ([[startTime]] – [[endTime]], [[direction]])"
        },
        "args": [
          {
            "name": "startTime",
            "type": "time",
            "title": {
              "en": "Start time"
            }
          },
          {
            "name": "endTime",
            "type": "time",
            "title": {
              "en": "End time"
            }
          },
          {
            "name": "direction",
            "type": "dropdown",
            "title": {
              "en": "Direction"
            },
            "values": [
              {
                "id": "down",
                "title": {
                  "en": "Down (100.0% to 0.0%)"
                }
              },
              {
                "id": "up",
                "title": {
                  "en": "Up (0.0% to 100.0%)"
                }
              }
            ]
          }
        ],
        "tokens": [
          {
            "name": "value",
            "type": "number",
            "title": {
              "en": "Value (%)"
            },
            "example": 75
          }
        ]
      }
    ]
  }
}