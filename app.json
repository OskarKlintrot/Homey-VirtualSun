{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.klintrot.virtualsun",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "brandColor": "#167AFF",
  "platforms": [
    "local",
    "cloud"
  ],
  "name": {
    "en": "Virtual Sun"
  },
  "description": {
    "en": "Virtual sun automation."
  },
  "category": [
    "tools"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Oskar Klintrot",
    "email": "oskar.klintrot@gmail.com"
  },
  "support": "mailto:oskar.klintrot@gmail.com",
  "flow": {
    "triggers": [
      {
        "id": "sun-value-changed",
        "title": {
          "en": "Sun value changed"
        },
        "titleFormatted": {
          "en": "Sun value changed ([[startTime]] – [[endTime]], [[direction]], step [[step]]%)"
        },
        "args": [
          {
            "name": "startTime",
            "type": "time",
            "title": {
              "en": "Start time"
            }
          },
          {
            "name": "endTime",
            "type": "time",
            "title": {
              "en": "End time"
            }
          },
          {
            "name": "direction",
            "type": "dropdown",
            "title": {
              "en": "Direction"
            },
            "values": [
              {
                "id": "down",
                "title": {
                  "en": "Down (100.0% to 0.0%)"
                }
              },
              {
                "id": "up",
                "title": {
                  "en": "Up (0.0% to 100.0%)"
                }
              }
            ]
          },
          {
            "name": "step",
            "type": "number",
            "title": {
              "en": "Step (%)"
            },
            "value": 1,
            "min": 0.1,
            "max": 100,
            "step": 0.1,
            "placeholder": {
              "en": "1"
            }
          }
        ],
        "tokens": [
          {
            "name": "value",
            "type": "number",
            "title": {
              "en": "Value (%)"
            },
            "example": 75
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "ramp-value-integer",
        "title": {
          "en": "Ramp value from 100->0 to x->y (only on change)"
        },
        "titleFormatted": {
          "en": "Ramp [[input]]% to integer between [[x]] and [[y]]"
        },
        "args": [
          {
            "name": "input",
            "type": "number",
            "title": {
              "en": "Input value (%)"
            },
            "placeholder": {
              "en": "Use the trigger token Value (%)"
            }
          },
          {
            "name": "x",
            "type": "number",
            "title": {
              "en": "X at 100% (integer)"
            },
            "placeholder": {
              "en": "60"
            }
          },
          {
            "name": "y",
            "type": "number",
            "title": {
              "en": "Y at 0% (integer)"
            },
            "placeholder": {
              "en": "20"
            }
          }
        ],
        "tokens": [
          {
            "name": "ramped",
            "type": "number",
            "title": {
              "en": "Mapped Value (%)"
            },
            "example": 42
          }
        ]
      }
    ]
  }
}