{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.klintrot.virtualsun",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "brandColor": "#167AFF",
  "platforms": [
    "local",
    "cloud"
  ],
  "name": {
    "en": "Virtual Sun"
  },
  "description": {
    "en": "Virtual sun automation."
  },
  "category": [
    "tools"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Oskar Klintrot",
    "email": "oskar.klintrot@gmail.com"
  },
  "support": "mailto:oskar.klintrot@gmail.com",
  "api": {
    "getActiveVirtualSuns": {
      "method": "GET",
      "path": "/virtual-suns"
    },
    "getSunValueConfigurations": {
      "method": "GET",
      "path": "/sun-value-configurations"
    },
    "stopVirtualSun": {
      "method": "DELETE",
      "path": "/virtual-suns/:name"
    },
    "stopAllVirtualSuns": {
      "method": "DELETE",
      "path": "/virtual-suns-stop-all"
    }
  },
  "flow": {
    "triggers": [
      {
        "id": "sun-value-changed",
        "title": {
          "en": "Virtual sun value changed"
        },
        "titleFormatted": {
          "en": "Virtual sun changes [[startTime]]–[[endTime]] • [[direction]] • [[step]] pp/step"
        },
        "args": [
          {
            "name": "startTime",
            "type": "time",
            "title": {
              "en": "Start time"
            }
          },
          {
            "name": "endTime",
            "type": "time",
            "title": {
              "en": "End time"
            }
          },
          {
            "name": "direction",
            "type": "dropdown",
            "title": {
              "en": "Direction"
            },
            "values": [
              {
                "id": "down",
                "title": {
                  "en": "Down (100.0% to 0.0%)"
                }
              },
              {
                "id": "up",
                "title": {
                  "en": "Up (0.0% to 100.0%)"
                }
              }
            ]
          },
          {
            "name": "step",
            "type": "number",
            "title": {
              "en": "Step (%)"
            },
            "value": 1,
            "min": 0.1,
            "max": 100,
            "step": 0.1,
            "placeholder": {
              "en": "1"
            }
          }
        ],
        "tokens": [
          {
            "name": "value",
            "type": "number",
            "title": {
              "en": "Value (%)"
            },
            "example": 0.75
          }
        ]
      },
      {
        "id": "virtual-sun-value-changed",
        "title": {
          "en": "Virtual sun changed"
        },
        "titleFormatted": {
          "en": "Virtual sun [[name]] changes"
        },
        "args": [
          {
            "name": "name",
            "type": "autocomplete",
            "title": {
              "en": "Virtual Sun"
            },
            "placeholder": {
              "en": "Pick a virtual sun"
            }
          }
        ],
        "tokens": [
          {
            "name": "value",
            "type": "number",
            "title": {
              "en": "Value (%)"
            },
            "example": 0.75
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "virtual-sun-is-active",
        "title": {
          "en": "Virtual sun is active"
        },
        "titleFormatted": {
          "en": "Virtual sun [[name]] is active"
        },
        "args": [
          {
            "name": "name",
            "type": "autocomplete",
            "title": {
              "en": "Virtual sun"
            },
            "placeholder": {
              "en": "Pick a virtual sun"
            }
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "convert-range",
        "title": {
          "en": "Convert value from 100->0 (%) to x->y (%)"
        },
        "titleFormatted": {
          "en": "Convert [[input]]% to range between [[x]] and [[y]]"
        },
        "args": [
          {
            "name": "input",
            "type": "range",
            "title": {
              "en": "Input value"
            },
            "min": 0,
            "max": 1,
            "step": 0.001,
            "label": "%",
            "labelMultiplier": 100,
            "labelDecimals": 1
          },
          {
            "name": "x",
            "type": "range",
            "title": {
              "en": "X at 100%"
            },
            "value": 1,
            "min": 0,
            "max": 1,
            "step": 0.01,
            "label": "%",
            "labelMultiplier": 100,
            "labelDecimals": 0
          },
          {
            "name": "y",
            "type": "range",
            "title": {
              "en": "Y at 0%"
            },
            "value": 0,
            "min": 0,
            "max": 1,
            "step": 0.01,
            "label": "%",
            "labelMultiplier": 100,
            "labelDecimals": 0
          }
        ],
        "tokens": [
          {
            "name": "convertedValue",
            "type": "number",
            "title": {
              "en": "Converted value (%)"
            },
            "example": 0.42
          }
        ]
      },
      {
        "id": "get-virtual-sun-value",
        "title": {
          "en": "Get virtual sun value"
        },
        "titleFormatted": {
          "en": "Get value of virtual sun [[name]]"
        },
        "args": [
          {
            "name": "name",
            "type": "autocomplete",
            "title": {
              "en": "Virtual sun"
            },
            "placeholder": {
              "en": "morning-livingroom"
            }
          }
        ],
        "tokens": [
          {
            "name": "value",
            "type": "number",
            "title": {
              "en": "Value (%)"
            },
            "example": 0.75
          }
        ]
      },
      {
        "id": "virtual-sun-start",
        "title": {
          "en": "Virtual sun start"
        },
        "titleFormatted": {
          "en": "Virtual sun [[name]] • [[duration]] min • [[direction]] • [[step]] pp/step"
        },
        "args": [
          {
            "name": "name",
            "type": "autocomplete",
            "title": {
              "en": "Virtual sun"
            },
            "placeholder": {
              "en": "morning-livingroom"
            }
          },
          {
            "name": "duration",
            "type": "number",
            "title": {
              "en": "Duration (minutes)"
            },
            "min": 1,
            "max": 1440,
            "step": 1,
            "placeholder": {
              "en": "60"
            }
          },
          {
            "name": "direction",
            "type": "dropdown",
            "title": {
              "en": "Direction"
            },
            "values": [
              {
                "id": "down",
                "title": {
                  "en": "Down (100.0% to 0.0%)"
                }
              },
              {
                "id": "up",
                "title": {
                  "en": "Up (0.0% to 100.0%)"
                }
              }
            ]
          },
          {
            "name": "step",
            "type": "number",
            "title": {
              "en": "Step (%)"
            },
            "value": 1,
            "min": 0.1,
            "max": 100,
            "step": 0.1,
            "placeholder": {
              "en": "1"
            }
          }
        ]
      },
      {
        "id": "virtual-sun-stop",
        "title": {
          "en": "Stop virtual sun"
        },
        "titleFormatted": {
          "en": "Stop virtual sun [[name]]"
        },
        "args": [
          {
            "name": "name",
            "type": "autocomplete",
            "title": {
              "en": "Virtual sun"
            },
            "placeholder": {
              "en": "Pick a virtual sun"
            }
          }
        ]
      }
    ]
  }
}